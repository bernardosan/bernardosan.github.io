---
type Props = {
  lang?: "pt" | "en";
};

const { lang = "pt" } = Astro.props;

const content =
  lang === "en"
    ? {
        badge: "Free first call",
        title: "Power Platform mentoring",
        text:
          "Learn how to grow technically, position yourself better, and sell solutions to international clients.",
        cta: "View mentorship",
        mini: "Mentoring",
        href: "/en/mentoring/",
        collapseLabel: "Minimize mentoring popup",
        expandLabel: "Open mentoring popup",
      }
    : {
        badge: "Primeira consulta gratuita",
        title: "Mentoria Power Platform",
        text:
          "Aprende a evoluir tecnicamente, posicionar-te melhor e vender soluções para clientes internacionais.",
        cta: "Ver mentoria",
        mini: "Mentoria",
        href: "/mentoria/",
        collapseLabel: "Minimizar popup de mentoria",
        expandLabel: "Abrir popup de mentoria",
      };
---

<div class="mentor-popup-shell is-visible is-collapsed" data-mentor-popup>
  <article class="mentor-popup" data-mentor-popup-card>
    <button
      class="mentor-popup-close"
      type="button"
      aria-label={content.collapseLabel}
      data-mentor-popup-collapse
    >
      <svg viewBox="0 0 24 24" aria-hidden="true">
        <path d="M6 12h12"></path>
      </svg>
    </button>

    <div class="mentor-popup-badge">
      {content.badge}
    </div>

    <h3>{content.title}</h3>

    <p>{content.text}</p>

    <a class="mentor-popup-link" href={content.href}>
      {content.cta}
      <svg viewBox="0 0 24 24" aria-hidden="true">
        <path d="M5 12h14"></path>
        <path d="m13 6 6 6-6 6"></path>
      </svg>
    </a>
  </article>

  <button
    class="mentor-popup-mini"
    type="button"
    aria-label={content.expandLabel}
    aria-expanded="false"
    data-mentor-popup-expand
  >
    {content.mini}
  </button>
</div>

<style is:inline>
  .mentor-popup-shell[data-mentor-popup] {
    position: fixed !important;
    right: 24px !important;
    bottom: 24px !important;
    z-index: 99999 !important;
    display: block !important;
    visibility: visible !important;
    opacity: 1 !important;
    width: min(360px, calc(100vw - 32px)) !important;
    max-width: calc(100vw - 32px) !important;
    transform: translateY(0) scale(1) !important;
    pointer-events: auto !important;
  }

  .mentor-popup-shell[data-mentor-popup].is-collapsed {
    width: auto !important;
    pointer-events: none !important;
  }

  .mentor-popup-shell[data-mentor-popup].is-collapsed .mentor-popup {
    display: none !important;
    visibility: hidden !important;
    opacity: 0 !important;
    pointer-events: none !important;
  }

  .mentor-popup-shell[data-mentor-popup].is-collapsed .mentor-popup-mini {
    display: inline-flex !important;
    visibility: visible !important;
    opacity: 1 !important;
    pointer-events: auto !important;
  }

  .mentor-popup-shell[data-mentor-popup]:not(.is-collapsed) .mentor-popup {
    display: block !important;
    visibility: visible !important;
    opacity: 1 !important;
    pointer-events: auto !important;
  }

  .mentor-popup-shell[data-mentor-popup]:not(.is-collapsed) .mentor-popup-mini {
    display: none !important;
    visibility: hidden !important;
    pointer-events: none !important;
  }

  @media (max-width: 600px) {
    .mentor-popup-shell[data-mentor-popup] {
      right: 12px !important;
      bottom: 12px !important;
      max-width: calc(100vw - 24px) !important;
    }

    .mentor-popup-shell[data-mentor-popup]:not(.is-collapsed) {
      width: calc(100vw - 24px) !important;
    }

    .mentor-popup-mini {
      min-height: 44px !important;
      padding: 10px 14px !important;
      font-size: 13px !important;
    }
  }
</style>

<script is:inline>
  (() => {
    const popup = document.querySelector("[data-mentor-popup]");

    if (!popup) return;

    const collapseButton = popup.querySelector("[data-mentor-popup-collapse]");
    const expandButton = popup.querySelector("[data-mentor-popup-expand]");
    const popupCard = popup.querySelector("[data-mentor-popup-card]");

    const forceVisibleShell = () => {
      popup.style.setProperty("display", "block", "important");
      popup.style.setProperty("visibility", "visible", "important");
      popup.style.setProperty("opacity", "1", "important");
      popup.style.setProperty("transform", "translateY(0) scale(1)", "important");
    };

    const collapsePopup = () => {
      forceVisibleShell();
      popup.classList.add("is-visible");
      popup.classList.add("is-collapsed");
      popup.classList.remove("is-open");
      popup.style.setProperty("width", "auto", "important");
      popup.style.setProperty("pointer-events", "auto", "important");

      popupCard?.style.setProperty("display", "none", "important");
      popupCard?.style.setProperty("visibility", "hidden", "important");
      popupCard?.style.setProperty("pointer-events", "none", "important");

      expandButton?.style.setProperty("display", "inline-flex", "important");
      expandButton?.style.setProperty("visibility", "visible", "important");
      expandButton?.style.setProperty("opacity", "1", "important");
      expandButton?.style.setProperty("pointer-events", "auto", "important");
      expandButton?.setAttribute("aria-expanded", "false");
    };

    const expandPopup = () => {
      forceVisibleShell();
      popup.classList.add("is-visible");
      popup.classList.remove("is-collapsed");
      popup.classList.add("is-open");
      popup.style.removeProperty("width");
      popup.style.setProperty("pointer-events", "auto", "important");

      popupCard?.style.setProperty("display", "block", "important");
      popupCard?.style.setProperty("visibility", "visible", "important");
      popupCard?.style.setProperty("opacity", "1", "important");
      popupCard?.style.setProperty("pointer-events", "auto", "important");

      expandButton?.style.setProperty("display", "none", "important");
      expandButton?.style.setProperty("visibility", "hidden", "important");
      expandButton?.style.setProperty("pointer-events", "none", "important");
      expandButton?.setAttribute("aria-expanded", "true");
    };

    collapsePopup();

    collapseButton?.addEventListener("click", collapsePopup);
    expandButton?.addEventListener("click", expandPopup);
  })();
</script>
