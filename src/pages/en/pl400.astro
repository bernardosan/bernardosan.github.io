      let activeQuestions = [];
      const state = new Map();

      const quizContainer = document.getElementById("quizContainer");
      const progressText = document.getElementById("progressText");
      const progressBar = document.getElementById("progressBar");
      const answeredCount = document.getElementById("answeredCount");
      const questionCount = document.getElementById("questionCount");
      const scorePreview = document.getElementById("scorePreview");
      const finalResult = document.getElementById("finalResult");
      const finalButton = document.getElementById("showFinalResult");

      function shuffleArray(items) {
        const copy = [...items];
        for (let i = copy.length - 1; i > 0; i--) {
          const j = Math.floor(Math.random() * (i + 1));
          [copy[i], copy[j]] = [copy[j], copy[i]];
        }
        return copy;
      }

      function escapeHtml(value) {
        return String(value)
          .replace(/&/g, "&amp;")
          .replace(/</g, "&lt;")
          .replace(/>/g, "&gt;")
          .replace(/"/g, "&quot;")
          .replace(/'/g, "&#039;");
      }

      function getQuestion(id) {
        return activeQuestions.find((question) => question.id === Number(id));
      }

      function getOptionText(question, key) {
        const option = question.options.find((item) => item.key === key);
        return option ? `${option.key}. ${option.text}` : key;
      }

      function formatChoiceAnswers(question, answers) {
        if (!answers || answers.length === 0) {
          return "No answer selected";
        }
        return answers.map((key) => escapeHtml(getOptionText(question, key))).join("<br>");
      }

      function formatMatrixAnswers(question, selectedMap) {
        const selected = selectedMap || {};
        return `
          <div class="pl400-matrix-review-table">
            ${question.rows.map((row) => `
              <div class="pl400-matrix-review-line">
                <span>${escapeHtml(row.requirement)}</span>
                <strong>${selected[row.id] ? escapeHtml(selected[row.id]) : "No answer selected"}</strong>
              </div>
            `).join("")}
          </div>
        `;
      }

      function formatMatrixAnswerKey(question) {
        const answers = {};
        question.rows.forEach((row) => {
          answers[row.id] = row.answer;
        });
        return formatMatrixAnswers(question, answers);
      }

      function sameAnswerSet(a, b) {
        if (a.length !== b.length) return false;
        const left = [...a].sort();
        const right = [...b].sort();
        return left.every((value, index) => value === right[index]);
      }

      function getChoiceSelection(questionId) {
        return Array.from(document.querySelectorAll(`input[name="q-${questionId}"]:checked`)).map((item) => item.value);
      }

      function getMatrixSelection(question) {
        const selected = {};
        question.rows.forEach((row) => {
          const input = document.querySelector(`select[name="q-${question.id}-${row.id}"]`);
          selected[row.id] = input ? input.value : "";
        });
        return selected;
      }

      function countMatrixSelections(selected) {
        return Object.values(selected || {}).filter(Boolean).length;
      }

      function isMatrixComplete(question, selected) {
        return question.rows.every((row) => Boolean(selected[row.id]));
      }

      function isMatrixCorrect(question, selected) {
        return question.rows.every((row) => selected[row.id] === row.answer);
      }

      function getQuestionSelection(question) {
        if (question.type === "matrix") {
          return getMatrixSelection(question);
        }
        return getChoiceSelection(question.id);
      }

      function isQuestionAnswered(question, selected) {
        if (question.type === "matrix") {
          return isMatrixComplete(question, selected);
        }
        return Array.isArray(selected) && selected.length === getRequiredCount(question);
      }

      function isQuestionCorrect(question, selected) {
        if (question.type === "matrix") {
          return isMatrixComplete(question, selected) && isMatrixCorrect(question, selected);
        }
        return sameAnswerSet(selected, question.answers);
      }

      function formatSelectedAnswers(question, selected) {
        if (question.type === "matrix") {
          return formatMatrixAnswers(question, selected);
        }
        return formatChoiceAnswers(question, selected);
      }

      function formatCorrectAnswers(question) {
        if (question.type === "matrix") {
          return formatMatrixAnswerKey(question);
        }
        return formatChoiceAnswers(question, question.answers);
      }

      function getQuestionBadge(question) {
        if (question.badge) return question.badge;
        if (question.type === "matrix") return "Answer area";
        return question.answers.length > 1 ? "Multiple answers" : "Single answer";
      }

      function getQuestionNote(question) {
        const requiredCount = getRequiredCount(question);

        if (question.type === "matrix") {
          if (question.uniqueSelection) {
            return `Text-converted drag/drop: complete all ${requiredCount} rows. Each selected option is removed from the remaining rows.`;
          }
          return `This question requires all ${requiredCount} rows before it counts as answered.`;
        }

        if (question.answers.length > 1) {
          return `Multiple-answer question: select ${requiredCount} options.`;
        }

        return "Optional: use Show answer when you are ready to compare.";
      }

      function renderImageMarkup(question, mode) {
        return "";
      }

      function renderExplanationImage(question) {
        if (!question.explanationImage) return "";
        return `
          <figure class="pl400-question-media pl400-explanation-media">
            <img src="${escapeHtml(question.explanationImage)}" alt="Explanation image for ${escapeHtml(question.sourceLabel || `Question #${question.id}`)}" loading="lazy" />
          </figure>
        `;
      }

      function renderQuestionExtras(question) {
        if (!question.code) return "";
        return `
          <pre class="pl400-code-block"><code>${escapeHtml(question.code)}</code></pre>
        `;
      }

      function renderChoiceQuestion(question) {
        const isMultiple = question.answers.length > 1;
        const inputType = isMultiple ? "checkbox" : "radio";
        return `
          <div class="pl400-options">
            ${question.options.map((option) => `
              <label class="pl400-option">
                <input class="pl400-option-input" type="${inputType}" name="q-${question.id}" value="${escapeHtml(option.key)}" data-question-id="${question.id}" />
                <span class="pl400-option-key">${escapeHtml(option.key)}</span>
                <span class="pl400-option-text">${escapeHtml(option.text)}</span>
              </label>
            `).join("")}
          </div>
        `;
      }

      function renderMatrixQuestion(question) {
        return `
          <div class="pl400-answer-area" role="group" aria-label="Answer area for ${escapeHtml(question.sourceLabel || `Question #${question.id}`)}">
            <div class="pl400-answer-area-head">
              <strong>Answer area</strong>
              <span>${question.uniqueSelection ? "Select each option once. Chosen options are removed from the remaining rows." : "Select one option for each row."}</span>
            </div>
            <div class="pl400-matrix-card">
              ${question.rows.map((row, index) => `
                <div class="pl400-matrix-row">
                  <div class="pl400-matrix-requirement">
                    <span>Requirement ${index + 1}</span>
                    <strong>${escapeHtml(row.requirement)}</strong>
                  </div>
                  <label class="pl400-matrix-control">
                    <span>${escapeHtml(row.label || "Answer")}</span>
                    <select class="pl400-matrix-select" name="q-${question.id}-${row.id}" data-question-id="${question.id}" data-unique-selection="${question.uniqueSelection ? "true" : "false"}">
                      <option value="">Select an option</option>
                      ${row.options.map((option) => `<option value="${escapeHtml(option)}">${escapeHtml(option)}</option>`).join("")}
                    </select>
                  </label>
                </div>
              `).join("")}
            </div>
          </div>
        `;
      }

      function renderQuestionBody(question) {
        if (question.type === "matrix") {
          return renderMatrixQuestion(question);
        }
        return renderChoiceQuestion(question);
      }

      function syncUniqueMatrixOptions(question) {
        if (!question || question.type !== "matrix" || !question.uniqueSelection) return;

        const selects = Array.from(document.querySelectorAll(`.pl400-matrix-select[data-question-id="${question.id}"]`));
        const selectedValues = new Set(selects.map((select) => select.value).filter(Boolean));

        selects.forEach((select) => {
          Array.from(select.options).forEach((option) => {
            if (!option.value) return;
            const selectedInAnotherRow = option.value !== select.value && selectedValues.has(option.value);
            option.disabled = selectedInAnotherRow;
            option.hidden = selectedInAnotherRow;
          });
        });
      }

      function renderQuiz() {
        state.clear();
        clearFinalResult();

        activeQuestions = shuffleArray(questions).slice(0, Math.min(MAX_QUESTIONS, questions.length));
        if (questionCount) questionCount.textContent = activeQuestions.length;

        quizContainer.innerHTML = activeQuestions.map((question, index) => `
          <article class="pl400-question-card" id="card-${question.id}">
            <div class="pl400-question-head">
              <div>
                <div class="pl400-question-kicker">Question ${index + 1} of ${activeQuestions.length} · ${escapeHtml(question.sourceLabel || `Original #${question.id}`)}</div>
                <p class="pl400-question-text">${escapeHtml(question.text)}</p>
                ${renderQuestionExtras(question)}
              </div>
              <span class="pl400-question-badge">${escapeHtml(getQuestionBadge(question))}</span>
            </div>

            ${renderQuestionBody(question)}

            <div class="pl400-question-actions">
              <button class="secondary-button pl400-action-button pl400-check-answer pl400-show-answer" type="button" data-question-id="${question.id}" aria-expanded="false">
                Show answer
              </button>
              <span>${escapeHtml(getQuestionNote(question))}</span>
            </div>

            <div class="pl400-result-box hidden" id="result-${question.id}"></div>
          </article>
        `).join("");

        activeQuestions.forEach(syncUniqueMatrixOptions);
        updateProgress();
        window.scrollTo({ top: 0, behavior: "smooth" });
      }

      function updateProgress() {
        let answered = 0;
        let correct = 0;

        activeQuestions.forEach((question) => {
          const item = state.get(question.id);
          if (item && item.answered) {
            answered += 1;
            if (item.correct) correct += 1;
          }
        });

        const total = activeQuestions.length;
        const percentageAnswered = total ? Math.round((answered / total) * 100) : 0;
        const partialScore = answered ? Math.round((correct / answered) * 100) : 0;

        progressText.textContent = `${answered} of ${total} answered`;
        progressBar.style.width = `${percentageAnswered}%`;
        if (answeredCount) answeredCount.textContent = answered;
        if (scorePreview) scorePreview.textContent = `${partialScore}%`;
      }

      function setFinalButtonVisible(isVisible) {
        if (!finalButton) return;
        finalButton.hidden = !isVisible;
      }

      function clearFinalResult() {
        finalResult.classList.add("hidden");
        finalResult.innerHTML = "";
        setFinalButtonVisible(true);
      }

      function setAnswerButtonState(questionId, revealed) {
        const button = document.querySelector(`.pl400-show-answer[data-question-id="${questionId}"]`);
        if (!button) return;
        button.textContent = revealed ? "Hide answer" : "Show answer";
        button.setAttribute("aria-expanded", revealed ? "true" : "false");
      }

      function hideQuestionFeedback(questionId) {
        const feedback = document.getElementById(`result-${questionId}`);
        feedback.className = "pl400-result-box hidden";
        feedback.innerHTML = "";
      }

      function getSelectedCount(question, selected) {
        if (question.type === "matrix") return countMatrixSelections(selected);
        return selected.length;
      }

      function getRequiredCount(question) {
        if (question.type === "matrix") return question.rows.length;
        return question.answers.length > 1 ? question.answers.length : 1;
      }

      function isSelectionComplete(question, selected) {
        if (question.type === "matrix") {
          return isMatrixComplete(question, selected);
        }
        return getSelectedCount(question, selected) === getRequiredCount(question);
      }

      function renderQuestionResult(question, selected, correct, heading = null) {
        return `
          <strong>${heading || (correct ? "Correct." : "Incorrect.")}</strong>
          <div class="pl400-answer-comparison">
            <div><b>Your answer:</b><br>${formatSelectedAnswers(question, selected)}</div>
            <div><b>Answer key:</b><br>${formatCorrectAnswers(question)}</div>
          </div>
          ${question.explanation ? `<div><b>Explanation:</b> ${escapeHtml(question.explanation)}</div>` : ""}
          ${renderExplanationImage(question)}
        `;
      }

      function showIncompleteSelectionWarning(question, selected, selectedCount, requiredCount, shouldReveal = false) {
        const feedback = document.getElementById(`result-${question.id}`);
        const title = question.type === "matrix" ? "Answer area incomplete." : "Multiple-answer question.";
        const message = question.type === "matrix"
          ? `Complete all ${requiredCount} rows before this question is counted.`
          : selectedCount > requiredCount
            ? `This question requires exactly ${requiredCount} options. Adjust your selection before this question is counted.`
            : `Select ${requiredCount} options before this question is counted.`;

        feedback.className = "pl400-result-box warning";
        feedback.innerHTML = `
          <strong>${title}</strong>
          <div>You selected ${selectedCount} of ${requiredCount} required items. ${message}</div>
          ${shouldReveal ? renderQuestionResult(question, selected, false, "Answer key.") : ""}
        `;
      }

      function updateQuestionState(questionId, shouldReveal = null) {
        const question = getQuestion(questionId);
        if (!question) return;

        const selected = getQuestionSelection(question);
        if (question.type === "matrix") syncUniqueMatrixOptions(question);
        const selectedCount = getSelectedCount(question, selected);
        const requiredCount = getRequiredCount(question);
        const previous = state.get(question.id);
        const revealAnswer = shouldReveal === null || typeof shouldReveal === "undefined"
          ? Boolean(previous && previous.revealed)
          : Boolean(shouldReveal);

        setAnswerButtonState(question.id, revealAnswer);
        clearFinalResult();

        if (!selectedCount) {
          if (!revealAnswer) {
            state.delete(question.id);
            hideQuestionFeedback(question.id);
            updateProgress();
            return;
          }

          state.set(question.id, {
            selected,
            answered: false,
            correct: false,
            revealed: true
          });

          const feedback = document.getElementById(`result-${question.id}`);
          feedback.className = "pl400-result-box warning";
          feedback.innerHTML = `
            <strong>No answer selected.</strong>
            <div>This question will not count as answered until you select the required item${requiredCount > 1 ? "s" : ""}.</div>
            ${renderQuestionResult(question, selected, false, "Answer key.")}
          `;
          updateProgress();
          return;
        }

        if (!isSelectionComplete(question, selected)) {
          state.set(question.id, {
            selected,
            answered: false,
            correct: false,
            revealed: revealAnswer
          });
          showIncompleteSelectionWarning(question, selected, selectedCount, requiredCount, revealAnswer);
          updateProgress();
          return;
        }

        const correct = isQuestionCorrect(question, selected);
        state.set(question.id, {
          selected,
          answered: true,
          correct,
          revealed: revealAnswer
        });

        if (revealAnswer) {
          const feedback = document.getElementById(`result-${question.id}`);
          feedback.className = `pl400-result-box ${correct ? "correct" : "wrong"}`;
          feedback.innerHTML = renderQuestionResult(question, selected, correct);
        } else {
          hideQuestionFeedback(question.id);
        }

        updateProgress();
      }

      function getDiagnosis(score, correct, wrong, notAnswered, total) {
        const unansweredText = notAnswered > 0
          ? ` You also left ${notAnswered} question${notAnswered === 1 ? "" : "s"} unanswered, so start there before interpreting the score.`
          : "";

        if (score >= PASSING_SCORE) {
          return {
            status: "good",
            title: `You reached the ${PASSING_SCORE}% passing score for this practice set.`,
            text: `This is a positive signal, but it should not be treated as a guarantee for the official exam. Review the questions you missed, confirm the related concepts, and use this result to decide what still needs practice.${unansweredText}`
          };
        }

        if (score >= 60) {
          return {
            status: "near",
            title: `You are close to the ${PASSING_SCORE}% passing score.`,
            text: `Focus on the questions marked incorrect and look for patterns: plug-ins, Dataverse, custom connectors, portals, integrations, or model-driven app behavior. A short targeted review can make the next attempt much more useful.${unansweredText}`
          };
        }

        if (score >= 40) {
          return {
            status: "review",
            title: `You are below the ${PASSING_SCORE}% passing score.`,
            text: `Use this attempt as a map of weak areas rather than as a pass/fail judgment. Revisit the core PL-400 topics, then retake the practice set with the questions shuffled.${unansweredText}`
          };
        }

        return {
          status: "foundation",
          title: "Reinforce the foundations before using exam-style questions as a benchmark.",
          text: `This score suggests that the fundamentals need more attention. Start with Dataverse, app types, Power Automate, plug-ins, connectors, portals, security, and integration patterns, then come back to these questions to measure improvement.${unansweredText}`
        };
      }

      function buildFinalResult() {
        let correct = 0;
        let wrong = 0;
        let notAnswered = 0;

        const rows = activeQuestions.map((question, index) => {
          const selected = getQuestionSelection(question);
          const isAnswered = isQuestionAnswered(question, selected);
          const isCorrect = isAnswered && isQuestionCorrect(question, selected);

          if (!isAnswered) notAnswered += 1;
          else if (isCorrect) correct += 1;
          else wrong += 1;

          const previous = state.get(question.id);
          state.set(question.id, {
            selected,
            answered: isAnswered,
            correct: isCorrect,
            revealed: Boolean(previous && previous.revealed)
          });

          const statusText = !isAnswered ? "Not answered" : isCorrect ? "Correct" : "Incorrect";
          const statusClass = !isAnswered ? "not-answered" : isCorrect ? "correct" : "wrong";

          return `
            <div class="pl400-review-row ${statusClass}">
              <div class="pl400-review-title">
                <span>Question ${index + 1} · ${escapeHtml(question.sourceLabel || `Original #${question.id}`)}</span>
                <span>${statusText}</span>
              </div>
              <p><b>Your answer:</b><br>${formatSelectedAnswers(question, selected)}</p>
              <p><b>Answer key:</b><br>${formatCorrectAnswers(question)}</p>
              ${question.explanation ? `<p><b>Explanation:</b> ${escapeHtml(question.explanation)}</p>` : ""}
              ${renderExplanationImage(question)}
            </div>
          `;
        }).join("");

        const total = activeQuestions.length;
        const score = total ? Math.round((correct / total) * 100) : 0;

        const diagnosis = getDiagnosis(score, correct, wrong, notAnswered, total);

        finalResult.classList.remove("hidden");
        setFinalButtonVisible(false);
        finalResult.innerHTML = `
          <div class="pl400-final-grid">
            <div class="pl400-final-item"><strong>${score}%</strong><span>Final score</span></div>
            <div class="pl400-final-item"><strong>${PASSING_SCORE}%</strong><span>Passing score</span></div>
            <div class="pl400-final-item"><strong>${correct}</strong><span>Correct</span></div>
            <div class="pl400-final-item"><strong>${wrong}</strong><span>Incorrect</span></div>
            <div class="pl400-final-item"><strong>${notAnswered}</strong><span>Not answered</span></div>
          </div>

          <div class="pl400-review-list">${rows}</div>

          <div class="pl400-diagnosis ${diagnosis.status}">
            <span>Diagnosis</span>
            <h3>${escapeHtml(diagnosis.title)}</h3>
            <p>${escapeHtml(diagnosis.text)}</p>
            <p class="pl400-diagnosis-note">
              This practice set is a learning checkpoint, not a reliable predictor of whether you would pass the official exam. Use the result to understand which areas need more attention before you continue your preparation.
            </p>
          </div>
        `;

        updateProgress();
        finalResult.scrollIntoView({ behavior: "smooth", block: "start" });
      }

      quizContainer.addEventListener("change", (event) => {
        if (!event.target.classList.contains("pl400-option-input") && !event.target.classList.contains("pl400-matrix-select")) return;

        const questionId = Number(event.target.dataset.questionId);
        const question = getQuestion(questionId);
        syncUniqueMatrixOptions(question);
        updateQuestionState(questionId);
      });

      quizContainer.addEventListener("click", (event) => {
        const button = event.target.closest(".pl400-show-answer");
        if (!button) return;

        const questionId = Number(button.dataset.questionId);
        const current = state.get(questionId);
        const nextRevealState = !(current && current.revealed);
        updateQuestionState(questionId, nextRevealState);
      });

      finalButton.addEventListener("click", buildFinalResult);
      document.getElementById("shuffleAgain").addEventListener("click", renderQuiz);

      renderQuiz();
    </script>
  </body>
</html>
