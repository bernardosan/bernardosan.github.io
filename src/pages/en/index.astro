---
import "../../styles/global.css";

const capabilities = [
  {
    title: "Power Platform Solutions",
    description:
      "Development of Power Apps, Power Automate, Dataverse and enterprise solutions integrated with the Microsoft ecosystem."
  },
  {
    title: "Business Intelligence",
    description:
      "Power BI dashboards, data models, executive KPIs and reporting solutions for better decision-making."
  },
  {
    title: "Process Automation",
    description:
      "Automation of approvals, notifications, manual tasks and repetitive operational workflows."
  },
  {
    title: "Dynamics 365 & Dataverse",
    description:
      "Customizations, data modeling, business rules, security and extensions for CRM environments."
  },
  {
    title: "Integration Engineering",
    description:
      "Integrations with REST APIs, C#/.NET, SQL Server, custom connectors and external business systems."
  },
  {
    title: "Adoption & Continuous Improvement",
    description:
      "Technical assessment, solution design, documentation, training and support for internal adoption."
  }
];

const useCases = [
  {
    title: "Financial services",
    description:
      "Internal applications, automations, Dataverse, integrations and reporting for controlled and process-driven environments.",
    companies: [
      {
        name: "Natixis",
        logo: "/images/companies/natixis.png"
      },
      {
        name: "Arrow Global",
        logo: "/images/companies/arrow-global.png"
      }
    ]
  },
  {
    title: "Industrial operations",
    description:
      "Process monitoring, operational dashboards, SQL databases and digitalization of local workflows.",
    companies: [
      {
        name: "IKEA",
        logo: "/images/companies/ikea.png"
      }
    ]
  },
  {
    title: "PMO and executive management",
    description:
      "KPIs, performance reporting, delivery tracking and consolidated information for management teams.",
    companies: [
      {
        name: "Stellantis",
        logo: "/images/companies/stellantis.png"
      },
      {
        name: "HORSE",
        logo: "/images/companies/horse.webp"
      }
    ]
  }
];

const process = [
  {
    step: "01",
    title: "Assessment",
    description:
      "Mapping the current process, available data, involved systems and key inefficiency points."
  },
  {
    step: "02",
    title: "Solution Design",
    description:
      "Defining the architecture, suitable Microsoft tools, required integrations and delivery roadmap."
  },
  {
    step: "03",
    title: "Implementation",
    description:
      "Building the solution with a focus on security, scalability, usability and business value."
  },
  {
    step: "04",
    title: "Adoption",
    description:
      "Documentation, user validation, continuous improvement and support for team adoption."
  }
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Bernardo Souza | Power Platform & Business Intelligence</title>
    <meta
      name="description"
      content="Power Platform Developer and Power BI Consultant. Solutions with Power Apps, Power Automate, Dataverse, Dynamics 365, Power BI, .NET, APIs and SQL."
    />
    <link rel="alternate" hreflang="pt" href="/" />
    <link rel="alternate" hreflang="en" href="/en/" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <meta name="theme-color" content="#2563eb" />
  </head>

  <body>
    <header class="site-header">
      <div class="header-inner">
        <a class="brand" href="/en/">
          <span class="brand-mark">BS</span>
          <span class="brand-text">
            <strong>Bernardo Souza</strong>
            <small>Power Platform & Data Solutions</small>
          </span>
        </a>

        <nav class="main-nav">
          <a href="#ecosystem">Ecosystem</a>
          <a href="#capabilities">Capabilities</a>
          <a href="#use-cases">Use cases</a>
          <a href="#process">Delivery</a>
          <a href="#contact">Contact</a>
        </nav>

        <div class="header-actions">
          <div class="language-switch" aria-label="Select language">
            <span class="language-globe">🌐</span>
            <a href="/">PT</a>
            <span>/</span>
            <a class="active" href="/en/" aria-current="page">EN</a>
          </div>

          <a class="header-button" href="#contact">Request assessment</a>
        </div>
      </div>
    </header>

    <main>
      <section class="hero">
        <div class="hero-inner">
          <div class="hero-copy">
            <div class="eyebrow">Microsoft Power Platform Advisory</div>

            <h1>Enterprise automation, analytics and systems integration.</h1>

            <p>
              Power Platform and Business Intelligence solutions for companies
              that need to reduce manual work, improve business metrics and
              integrate processes across the Microsoft ecosystem.
            </p>

            <div class="hero-actions">
              <a class="primary-button" href="#contact">Request assessment</a>
              <a class="secondary-button" href="#ecosystem">View technologies</a>
            </div>

            <div class="tech-strip" aria-label="Main technologies">
              <span>Power BI</span>
              <span>Power Apps</span>
              <span>Power Automate</span>
              <span>Dataverse</span>
              <span>Dynamics 365</span>
              <span>.NET</span>
              <span>SQL</span>
            </div>
          </div>

          <aside class="hero-visual" aria-label="Technical specialization">
            <div class="platform-hero-card">
              <div class="hero-platform-header">
                <img
                  src="/images/power-platform.svg"
                  alt="Microsoft Power Platform"
                  class="platform-main-logo"
                />
                <div>
                  <span>Microsoft Power Platform</span>
                  <strong>Low-code + data + integrations</strong>
                </div>
              </div>

              <p>
                Architecture, development and delivery of business solutions
                focused on processes, automation, reporting and integration.
              </p>

              <div class="architecture-flow" aria-label="Solution flow">
                <div>Processes</div>
                <span></span>
                <div>Automation</div>
                <span></span>
                <div>Data</div>
                <span></span>
                <div>Decisions</div>
              </div>
            </div>

            <div class="hero-tools">
              <div class="hero-tool is-bi">
                <img src="/images/power-bi.png" alt="Power BI" />
                <div>
                  <span>Power BI</span>
                  <strong>Dashboards & KPIs</strong>
                </div>
              </div>

              <div class="hero-tool is-apps">
                <img src="/images/power-apps.png" alt="Power Apps" />
                <div>
                  <span>Power Apps</span>
                  <strong>Internal apps</strong>
                </div>
              </div>

              <div class="hero-tool is-flow">
                <img src="/images/power-automate.png" alt="Power Automate" />
                <div>
                  <span>Power Automate</span>
                  <strong>Workflows</strong>
                </div>
              </div>

              <div class="hero-tool is-code">
                <img src="/images/sql-net-green.svg" alt="SQL Server" />
                <div>
                  <span>.NET / SQL</span>
                  <strong>Integrations</strong>
                </div>
              </div>
            </div>
          </aside>
        </div>
      </section>

      <section id="ecosystem" class="platform-section">
        <div class="container">
          <div class="section-heading section-heading-center">
            <span>Microsoft ecosystem</span>
            <h2>Technologies for digitalization, automation and reporting.</h2>
            <p>
              Integrated tools combining low-code, data and technical
              development to create measurable business impact.
            </p>
          </div>

          <div class="platform-grid platform-grid-icons">
            <article class="platform-card is-platform">
              <div class="platform-icon-img">
                <img src="/images/power-platform.svg" alt="Power Platform" />
              </div>
              <h3>Power Platform</h3>
              <p>Foundation for business apps, automation, data and processes.</p>
            </article>

            <article class="platform-card is-bi">
              <div class="platform-icon-img">
                <img src="/images/power-bi.png" alt="Power BI" />
              </div>
              <h3>Power BI</h3>
              <p>Dashboards, KPIs, data models and executive reporting.</p>
            </article>

            <article class="platform-card is-apps">
              <div class="platform-icon-img">
                <img src="/images/power-apps.png" alt="Power Apps" />
              </div>
              <h3>Power Apps</h3>
              <p>Internal applications to replace manual business processes.</p>
            </article>

            <article class="platform-card is-flow">
              <div class="platform-icon-img">
                <img src="/images/power-automate.png" alt="Power Automate" />
              </div>
              <h3>Power Automate</h3>
              <p>Automation of approvals, alerts, integrations and repetitive tasks.</p>
            </article>
          </div>

          <div class="stack-band" aria-label="Additional stack">
            <span>Dataverse</span>
            <span>Dynamics 365</span>
            <span>C# / .NET</span>
            <span>REST APIs</span>
            <span>SQL Server</span>
            <span>Azure Data Lake</span>
          </div>
        </div>
      </section>

      <section id="capabilities" class="section">
        <div class="container">
          <div class="section-heading">
            <span>Capabilities</span>
            <h2>Solutions for operations, data and automation.</h2>
            <p>
              Services designed for companies that need to modernize internal
              processes without creating unnecessary technical complexity.
            </p>
          </div>

          <div class="cards-grid">
            {
              capabilities.map((item) => (
                <article class="card">
                  <h3>{item.title}</h3>
                  <p>{item.description}</p>
                </article>
              ))
            }
          </div>
        </div>
      </section>

      <section id="use-cases" class="section section-muted">
        <div class="container">
          <div class="section-heading">
            <span>Use cases</span>
            <h2>Practical applications in business environments.</h2>
            <p>
              Experience applied to consulting, industrial operations, executive
              reporting and digital transformation contexts.
            </p>
          </div>

          <div class="use-case-grid">
            {
              useCases.map((item) => (
                <article class="use-case-card">
                  <h3>{item.title}</h3>
                  <p>{item.description}</p>

                  <div class="company-logos" aria-label="Related companies">
                    {
                      item.companies.map((company) => (
                        <div class="company-logo-chip">
                          <img src={company.logo} alt={company.name} loading="lazy" />
                        </div>
                      ))
                    }
                  </div>
                </article>
              ))
            }
          </div>
        </div>
      </section>

      <section id="process" class="section">
        <div class="container">
          <div class="section-heading">
            <span>Delivery model</span>
            <h2>From initial assessment to team adoption.</h2>
            <p>
              A structured process to deliver useful, sustainable solutions
              aligned with business goals.
            </p>
          </div>

          <div class="process-grid">
            {
              process.map((item) => (
                <article class="process-card">
                  <span>{item.step}</span>
                  <h3>{item.title}</h3>
                  <p>{item.description}</p>
                </article>
              ))
            }
          </div>
        </div>
      </section>

      <section id="contact" class="contact-form-section">
        <div class="container contact-form-grid">
          <div class="contact-form-copy">
            <span>Next step</span>

            <h2>Let’s assess an automation or BI opportunity.</h2>

            <p>
              Send a brief description of the process, report or integration you want
              to improve. From there, we can define a technical approach and an
              initial scope.
            </p>

            <ul class="contact-points">
              <li>
                <strong>Initial assessment</strong>
                <span>Understanding the process, tools and data involved.</span>
              </li>
              <!--
              <li>
                <strong>Technical recommendation</strong>
                <span>
                  Guidance on the right approach with Power Platform, BI, APIs or SQL.
                </span>
              </li>

              <li>
                <strong>Email response</strong>
                <span>Follow-up with next steps and a possible work scope.</span>
              </li>
            </ul> -->

            <div class="direct-contact">
              <span>Prefer direct contact?</span>
              <a href="mailto:bernardosantiagodesouza@gmail.com">
                bernardosantiagodesouza@gmail.com
              </a>
            </div>
          </div>

          <div class="form-card">
            <iframe
              class="tally-form"
              data-tally-src="https://tally.so/embed/ZjvEl0?alignLeft=1&hideTitle=1&transparentBackground=1&dynamicHeight=1"
              loading="lazy"
              width="100%"
              height="576"
              frameborder="0"
              marginheight="0"
              marginwidth="0"
              title="Contact form - Bernardo Souza"
            ></iframe>
          </div>
        </div>
      </section>
    </main>

    <footer class="footer">
      <div>
        <strong>Bernardo Souza</strong>
        <p>Power Platform · Business Intelligence · Automation · Integration</p>
      </div>

      <p><a href="/en/privacy/">Privacy Policy</a></p>

      <p>© 2026. All rights reserved.</p>
    </footer>

    <script is:inline>
      var d = document;
      var w = "https://tally.so/widgets/embed.js";

      var v = function () {
        if (typeof Tally !== "undefined") {
          Tally.loadEmbeds();
        } else {
          d.querySelectorAll("iframe[data-tally-src]:not([src])").forEach(function (e) {
            e.src = e.dataset.tallySrc;
          });
        }
      };

      if (typeof Tally !== "undefined") {
        v();
      } else if (d.querySelector('script[src="' + w + '"]') == null) {
        var s = d.createElement("script");
        s.src = w;
        s.onload = v;
        s.onerror = v;
        d.body.appendChild(s);
      }
    </script>
  </body>
</html>
