---
import "../styles/global.css";
import MentoringPopup from "../components/MentoringPopup.astro";

const capabilities = [
  {
    title: "Soluções Power Platform",
    description:
      "Desenvolvimento de Power Apps, Power Automate, Dataverse e soluções empresariais integradas ao ecossistema Microsoft."
  },
  {
    title: "Inteligência de Negócio",
    description:
      "Dashboards Power BI, modelos de dados, KPIs executivos e relatórios para suporte à decisão."
  },
  {
    title: "Automação de processos",
    description:
      "Automação de aprovações, notificações, tarefas manuais e fluxos operacionais repetitivos."
  },
  {
    title: "Dynamics 365 & Dataverse",
    description:
      "Customizações, modelagem de dados, regras de negócio, segurança e extensões para ambientes CRM."
  },
  {
    title: "Engenharia de integrações",
    description:
      "Integrações com APIs REST, C#/.NET, SQL Server, conectores personalizados e sistemas externos."
  },
  {
    title: "Adesão e melhoria contínua",
    description:
      "Diagnóstico técnico, desenho de solução, documentação, treinamento e suporte para adesão interna."
  }
];

const useCases = [
  {
    title: "Serviços financeiros",
    description:
      "Aplicações internas, automações, Dataverse, integrações e reporting para ambientes regulados e orientados a controlo.",
    companies: [
      {
        name: "Natixis",
        logo: "/images/companies/natixis.png"
      },
      {
        name: "Arrow Global",
        logo: "/images/companies/arrow-global.png"
      }
    ]
  },
  {
    title: "Operações industriais",
    description:
      "Monitorização de processos, dashboards operacionais, bases de dados SQL e digitalização de fluxos locais.",
    companies: [
      {
        name: "IKEA",
        logo: "/images/companies/ikea.png"
      }
    ]
  },
  {
    title: "PMO e gestão executiva",
    description:
      "KPIs, relatórios de performance, acompanhamento de entregas e consolidação de informação para gestão.",
    companies: [
      {
        name: "Stellantis",
        logo: "/images/companies/stellantis.png"
      },
      {
        name: "HORSE",
        logo: "/images/companies/horse.webp"
      }
    ]
  }
];

const process = [
  {
    step: "01",
    title: "Diagnóstico",
    description:
      "Mapeamento do processo atual, dados disponíveis, sistemas envolvidos e principais pontos de ineficiência."
  },
  {
    step: "02",
    title: "Desenho da solução",
    description:
      "Definição da arquitetura, ferramentas Microsoft adequadas, integrações necessárias e plano de entrega."
  },
  {
    step: "03",
    title: "Implementação",
    description:
      "Construção da solução com foco em segurança, escalabilidade, usabilidade e valor de negócio."
  },
  {
    step: "04",
    title: "Adesão",
    description:
      "Documentação, validação com utilizadores, melhoria contínua e suporte à adesão pelas equipas."
  }
];
---

<html lang="pt">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Bernardo Souza | Power Platform & Business Intelligence</title>
    <meta
      name="description"
      content="Power Platform Developer e Power BI Consultant. Soluções com Power Apps, Power Automate, Dataverse, Dynamics 365, Power BI, .NET, APIs e SQL."
    />
    <link rel="alternate" hreflang="pt" href="/" />
    <link rel="alternate" hreflang="en" href="/en/" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <meta name="theme-color" content="#2563eb" />
  </head>

  <body>
    <header class="site-header">
      <div class="header-inner">
        <a class="brand" href="/">
          <span class="brand-mark brand-mark-icon" aria-hidden="true">
            <img src="/favicon.svg" alt="" />
          </span>
          <span class="brand-text">
            <strong>Bernardo Souza</strong>
            <small>Power Platform & Dados</small>
          </span>
        </a>

        <nav class="main-nav">
          <a href="#ecossistema">Ecossistema</a>
          <a href="#capacidades">Capacidades</a>
          <a href="#casos">Casos de uso</a>
          <a href="#processo">Processo</a>
          <a href="#contacto">Contacto</a>
        </nav>

        <div class="header-actions">
          <div class="language-switch" aria-label="Selecionar idioma">
            <span class="language-globe">🌐</span>
            <a class="active" href="/" aria-current="page">PT</a>
            <span>/</span>
            <a href="/en/">EN</a>
          </div>

          <a class="header-button" href="#contacto">Solicitar avaliação</a>
        </div>
      </div>
    </header>

    <main>
      <section class="hero">
        <div class="hero-inner">
          <div class="hero-copy">
            <h1>Automação empresarial, analytics e integração de sistemas.</h1>

            <p>
              Soluções Power Platform e Business Intelligence para empresas que
              precisam reduzir trabalho manual, melhorar indicadores e integrar
              processos ao ecossistema Microsoft.
            </p>

            <div class="hero-actions">
              <a class="primary-button" href="#contacto">Solicitar avaliação</a>
              <a class="secondary-button" href="#ecossistema">Ver tecnologias</a>
            </div>

            <div class="tech-strip" aria-label="Tecnologias principais">
              <span>Power BI</span>
              <span>Power Apps</span>
              <span>Power Automate</span>
              <span>Dataverse</span>
              <span>Dynamics 365</span>
              <span>.NET</span>
              <span>SQL</span>
            </div>
          </div>

          <aside class="hero-visual" aria-label="Especialização técnica">
            <div class="platform-hero-card">
              <div class="hero-platform-header">
                <img
                  src="/images/power-platform.svg"
                  alt="Microsoft Power Platform"
                  class="platform-main-logo"
                />
                <div>
                  <span>Microsoft Power Platform</span>
                  <strong>Low-code + dados + integrações</strong>
                </div>
              </div>

              <p>
                Arquitetura, desenvolvimento e entrega de soluções corporativas
                com foco em processos, automação, reporting e integração.
              </p>

              <div class="architecture-flow" aria-label="Fluxo de solução">
                <div>Processos</div>
                <span></span>
                <div>Automação</div>
                <span></span>
                <div>Dados</div>
                <span></span>
                <div>Decisão</div>
              </div>
            </div>

            <div class="hero-tools">
              <div class="hero-tool is-bi">
                <img src="/images/power-bi.png" alt="Power BI" />
                <div>
                  <span>Power BI</span>
                  <strong>Dashboards & KPIs</strong>
                </div>
              </div>

              <div class="hero-tool is-apps">
                <img src="/images/power-apps.png" alt="Power Apps" />
                <div>
                  <span>Power Apps</span>
                  <strong>Aplicações internas</strong>
                </div>
              </div>

              <div class="hero-tool is-flow">
                <img src="/images/power-automate.png" alt="Power Automate" />
                <div>
                  <span>Power Automate</span>
                  <strong>Fluxos automatizados</strong>
                </div>
              </div>

              <div class="hero-tool is-code">
                <img src="/images/sql-net-green.svg" alt="SQL Server" />
                <div>
                  <span>.NET / SQL</span>
                  <strong>Integrações</strong>
                </div>
              </div>
            </div>
          </aside>
        </div>
      </section>

      <section id="ecossistema" class="platform-section">
        <div class="container">
          <div class="section-heading section-heading-center">
            <span>Ecossistema Microsoft</span>
            <h2>Tecnologias para digitalização, automação e reporting.</h2>
            <p>
              Ferramentas integradas que combinam low-code, dados e
              desenvolvimento técnico para gerar impacto real no negócio.
            </p>
          </div>

          <div class="platform-grid platform-grid-icons">
            <article class="platform-card is-platform">
              <div class="platform-icon-img">
                <img src="/images/power-platform.svg" alt="Power Platform" />
              </div>
              <h3>Power Platform</h3>
              <p>Base para aplicações, automações, dados e processos empresariais.</p>
            </article>

            <article class="platform-card is-bi">
              <div class="platform-icon-img">
                <img src="/images/power-bi.png" alt="Power BI" />
              </div>
              <h3>Power BI</h3>
              <p>Dashboards, KPIs, modelos de dados e reporting executivo.</p>
            </article>

            <article class="platform-card is-apps">
              <div class="platform-icon-img">
                <img src="/images/power-apps.png" alt="Power Apps" />
              </div>
              <h3>Power Apps</h3>
              <p>Aplicações internas para substituir processos manuais.</p>
            </article>

            <article class="platform-card is-flow">
              <div class="platform-icon-img">
                <img src="/images/power-automate.png" alt="Power Automate" />
              </div>
              <h3>Power Automate</h3>
              <p>Automação de aprovações, alertas, integrações e tarefas repetitivas.</p>
            </article>
          </div>

          <div class="stack-band" aria-label="Stack complementar">
            <span>Dataverse</span>
            <span>Dynamics 365</span>
            <span>C# / .NET</span>
            <span>REST APIs</span>
            <span>SQL Server</span>
            <span>Azure Data Lake</span>
          </div>
        </div>
      </section>

      <section id="capacidades" class="section">
        <div class="container">
          <div class="section-heading">
            <span>Capacidades</span>
            <h2>Soluções para operações, dados e automação.</h2>
            <p>
              Serviços desenhados para empresas que precisam modernizar
              processos internos sem criar complexidade desnecessária.
            </p>
          </div>

          <div class="cards-grid">
            {
              capabilities.map((item) => (
                <article class="card">
                  <h3>{item.title}</h3>
                  <p>{item.description}</p>
                </article>
              ))
            }
          </div>
        </div>
      </section>

      <section id="casos" class="section section-muted">
        <div class="container">
          <div class="section-heading">
            <span>Casos de uso</span>
            <h2>Aplicações práticas em ambientes empresariais.</h2>
            <p>
              Experiência aplicada em contextos de consultoria, operações
              industriais, reporting executivo e transformação digital.
            </p>
          </div>

          <div class="use-case-grid">
            {
              useCases.map((item) => (
                <article class="use-case-card">
                  <h3>{item.title}</h3>
                  <p>{item.description}</p>

                  <div class="company-logos" aria-label="Empresas relacionadas">
                    {
                      item.companies.map((company) => (
                        <div class="company-logo-chip">
                          <img src={company.logo} alt={company.name} loading="lazy" />
                        </div>
                      ))
                    }
                  </div>
                </article>
              ))
            }
          </div>
        </div>
      </section>

      <section id="processo" class="section">
        <div class="container">
          <div class="section-heading">
            <span>Modelo de entrega</span>
            <h2>Da análise inicial à adesão pela equipa.</h2>
            <p>
              Um processo estruturado para entregar soluções úteis, sustentáveis
              e alinhadas com objetivos de negócio.
            </p>
          </div>

          <div class="process-grid">
            {
              process.map((item) => (
                <article class="process-card">
                  <span>{item.step}</span>
                  <h3>{item.title}</h3>
                  <p>{item.description}</p>
                </article>
              ))
            }
          </div>
        </div>
      </section>

      <section id="contacto" class="contact-form-section">
        <div class="container contact-form-grid">
          <div class="contact-form-copy">
            <span>Próximo passo</span>

            <h2>Vamos avaliar uma oportunidade de automação ou BI?</h2>

            <p>
              Envie uma breve descrição do processo, relatório ou integração que
              pretende melhorar. A partir daí, é possível definir uma abordagem
              técnica e um escopo inicial.
            </p>

            <ul class="contact-points">
              <li>
                <strong>Diagnóstico inicial</strong>
                <span>Entendimento do processo, ferramentas e dados envolvidos.</span>
              </li>
              <!--
              <li>
                <strong>Recomendação técnica</strong>
                <span>
                  Indicação da melhor abordagem com Power Platform, BI, APIs ou SQL.
                </span>
              </li>

              <li>
                <strong>Resposta por email</strong>
                <span>Retorno com próximos passos e possível escopo de trabalho.</span>
              </li>
            </ul>-->

            <div class="direct-contact">
              <span>Preferes contacto direto?</span>
              <a href="mailto:bernardosantiagodesouza@gmail.com">
                bernardosantiagodesouza@gmail.com
              </a>
            </div>
          </div>

          <div class="form-card">
            <iframe
              class="tally-form"
              data-tally-src="https://tally.so/r/MevNxp?transparentBackground=1&dynamicHeight=1"
              loading="lazy"
              width="100%"
              height="576"
              frameborder="0"
              marginheight="0"
              marginwidth="0"
              title="Contact form - Bernardo Souza"
            ></iframe>
          </div>
        </div>
      </section>
    </main>

    <footer class="footer">
      <div>
        <strong>Bernardo Souza</strong>
        <p>Power Platform · Business Intelligence · Automação · Integrações</p>
      </div>

      <p><a href="/privacy/">Política de Privacidade</a></p>

      <p>© 2026. Todos os direitos reservados.</p>
    </footer>

    <MentoringPopup lang="pt" />

    <script is:inline>
      var d = document;
      var w = "https://tally.so/widgets/embed.js";

      var v = function () {
        if (typeof Tally !== "undefined") {
          Tally.loadEmbeds();
        } else {
          d.querySelectorAll("iframe[data-tally-src]:not([src])").forEach(function (e) {
            e.src = e.dataset.tallySrc;
          });
        }
      };

      if (typeof Tally !== "undefined") {
        v();
      } else if (d.querySelector('script[src="' + w + '"]') == null) {
        var s = d.createElement("script");
        s.src = w;
        s.onload = v;
        s.onerror = v;
        d.body.appendChild(s);
      }
    </script>
  </body>
</html>
